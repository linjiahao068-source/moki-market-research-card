# Moki Market - Environment Variables Example
# Copy this file to .env.local and fill in the actual values

# Financial Modeling Prep (FMP) API Key
# Used for earnings estimates and financial data
# Get a free API key from: https://financialmodelingprep.com/developer/docs/
FMP_API_KEY=

# SEC request identity. Recommended for SEC EDGAR requests.
SEC_USER_AGENT=Moki Market your-email@example.com

# LLM Research Brief MVP (server-side only; do not expose with NEXT_PUBLIC_)
# disabled | fallback | ark | deepseek | openai-compatible
LLM_PROVIDER=fallback
RESEARCH_GENERATION_ENABLED=false
LLM_TIMEOUT_MS=120000
# Set true only when the selected provider supports OpenAI response_format json_object.
LLM_JSON_MODE=false

# Volcengine Ark / 火山方舟 OpenAI-compatible endpoint.
# ARK_MODEL is usually the model or endpoint id configured in Ark.
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=

# DeepSeek-compatible fallback option.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=

# Generic OpenAI-compatible provider option.
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_MODEL=
