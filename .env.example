# SEC_USER_AGENT is required for SEC fair access identification.
SEC_USER_AGENT="Moki Market contact@example.com"

# Optional FMP API key. Leave empty to skip the FMP Provider.
FMP_API_KEY=""

# Optional Alpha Vantage API key. Leave empty to skip Alpha Vantage providers.
ALPHA_VANTAGE_API_KEY=""

# Expectations provider: fmp | mock | manual | disabled
EXPECTATIONS_PROVIDER=fmp

# Guidance provider: manual | mock | disabled
GUIDANCE_PROVIDER=manual

# Enable market expectation proxy (for future use)
ENABLE_MARKET_EXPECTATION_PROXY=false

# Enable earnings data debug API (for development use only)
# Also automatically disabled in NODE_ENV=production
DEBUG_EARNINGS_DATA=false
